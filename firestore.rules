rules_version = '2';

// Deploy via Firebase console (Firestore > Rules) or `firebase deploy --only firestore:rules`.
// Run scripts/migrateQuestions.mjs BEFORE deploying — these rules block client
// writes to the content collections, so afterwards content is managed in the console.
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    // Question text + options only. The correct answer is never stored here.
    match /questions/{questionId} {
      allow read: if signedIn();
      allow write: if false;
    }

    // The correct answer is readable only when:
    //  - the question belongs to the practice pool (unranked, learning is fine), or
    //  - this user has already locked in a daily answer for it.
    // This is the anti-cheat core: no client can see an answer before committing.
    match /questionAnswers/{questionId} {
      allow read: if signedIn() && (
        get(/databases/$(database)/documents/questions/$(questionId)).data.inPracticePool == true ||
        exists(/databases/$(database)/documents/users/$(request.auth.uid)/dailyAnswers/$(questionId))
      );
      allow write: if false;
    }

    // Daily quizzes are defined ahead of time but stay invisible until their
    // day arrives (availableAt) and they are published. Drafts stay hidden.
    match /dailyQuizzes/{quizDate} {
      allow read: if signedIn()
        && resource.data.status == 'published'
        && resource.data.availableAt <= request.time;
      allow write: if false;
    }

    match /users/{userId} {
      // Open read: username availability is checked before sign-up, and the
      // leaderboard reads all user docs.
      allow read: if true;
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && (
        request.auth.uid == userId ||
        // Friend invites add the new friend to the inviter's doc — allow
        // other users to touch the friends field and nothing else.
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friends'])
      );

      // One submission per question, forever. Answers can only be created for
      // questions that are part of an already-available quiz, and can never be
      // edited or deleted — so you can't peek at an answer and then change
      // your pick, and you can't unlock future quizzes' answers early.
      match /dailyAnswers/{questionId} {
        allow read: if signedIn() && request.auth.uid == userId;
        allow create: if signedIn() && request.auth.uid == userId
          && request.resource.data.quizDate is string
          && request.resource.data.choice is string
          && questionId in get(/databases/$(database)/documents/dailyQuizzes/$(request.resource.data.quizDate)).data.questionIds
          && get(/databases/$(database)/documents/dailyQuizzes/$(request.resource.data.quizDate)).data.availableAt <= request.time;
        allow update, delete: if false;
      }
    }
  }
}
