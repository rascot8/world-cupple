VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Optional — real-money checkout. One Stripe Payment Link per CupCoin bundle.
# When unset, the in-app sandbox checkout is used (no real charges).
# See "Monetization" in README.md + stripeWebhook in functions/index.js.
# VITE_STRIPE_LINK_STARTER=https://buy.stripe.com/...
# VITE_STRIPE_LINK_FAN=https://buy.stripe.com/...
# VITE_STRIPE_LINK_PRO=https://buy.stripe.com/...
# VITE_STRIPE_LINK_LEGEND=https://buy.stripe.com/...
